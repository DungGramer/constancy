{
  "name": "constancy",
  "version": "3.0.0",
  "description": "Zero-dependency immutability toolkit: freeze, view, snapshot, vault, and integrity verification",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "constancy",
    "constant",
    "freeze",
    "deep-freeze",
    "deepfreeze",
    "immutable",
    "immutability",
    "readonly",
    "object-freeze",
    "frozen",
    "typescript",
    "zero-dependency",
    "state-management"
  ],
  "homepage": "https://github.com/DungGramer/constancy#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/DungGramer/constancy.git"
  },
  "bugs": {
    "url": "https://github.com/DungGramer/constancy/issues"
  },
  "author": {
    "name": "DungGramer",
    "email": "dung.dev.gramer@gmail.com"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
